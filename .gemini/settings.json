{
  "$schema": "https://geminicli.com/schemas/settings.json",
  "model": {
    "name": "flash"
  },
  "model_aliases": {
    "pro": "gemini-3.1-pro-preview",
    "flash": "gemini-3-flash-preview"
  },
  "experimental": {
    "plan": true
  },
  "core": {
    "checkForUpdates": true,
    "theme": "Default"
  },
  "models": {
    "previewFeatures": true
  },
  "output": {
    "format": "text"
  },
  "tools": {
    "useRipgrep": true,
    "truncateLargeToolOutputs": true
  },
  "prompts": {
    "enableAiCompletions": true
  },
  "context": {
    "memorySearchIncludeDirectories": true
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "mcpServers": {
    "context7": {
      "httpUrl": "${CONTEXT7_URL:-https://mcp.context7.com/mcp}",
      "trust": true
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking",
        "--enable-fs-tools",
        "--enable-code-intel-tools"
      ],
      "trust": true
    },
    "chrome-dev-tools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated"
      ]
    }
  },
  "general": {
    "previewFeatures": true,
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "120d"
    },
    "defaultApprovalMode": "plan"
  },
  "ui": {
    "inlineThinkingMode": "full",
    "showStatusInTitle": true,
    "theme": "Default Light",
    "hideContextSummary": true
  }
}
